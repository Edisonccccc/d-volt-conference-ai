# Copy this file to backend/.env and fill in real values.
# backend/.env is gitignored; this file (.env.example) is committed as a
# template, so do NOT put real secrets here.

# Required: your Anthropic API key.
ANTHROPIC_API_KEY=sk-ant-api03-...

# Required for slice 2 server-side STT (audio -> Whisper -> Claude summary).
OPENAI_API_KEY=sk-proj-...

# Auth (slice 3). Generate with:  openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string
# Comma-separated list of email domains allowed to self-serve register.
# Empty/unset = anyone can register (dev only). For prod set to your domain.
EMAIL_ALLOWLIST=d-volt.co
JWT_EXPIRY_DAYS=7

# Optional overrides.
ANTHROPIC_MODEL=claude-sonnet-4-6
WHISPER_MODEL=whisper-1
DATA_DIR=./data
DB_PATH=./data/app.db
COMPANY_CONTEXT="d-volt sells voltage regulation and power conditioning hardware to industrial and commercial customers. Frame pain points and openings around power quality, energy savings, equipment reliability, and downtime reduction."
